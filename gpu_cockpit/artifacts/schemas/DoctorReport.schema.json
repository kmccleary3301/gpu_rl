{
  "$defs": {
    "HardwareFingerprint": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "default": "1.0.0",
          "title": "Schema Version",
          "type": "string"
        },
        "vendor": {
          "title": "Vendor",
          "type": "string"
        },
        "gpu_name": {
          "title": "Gpu Name",
          "type": "string"
        },
        "arch": {
          "title": "Arch",
          "type": "string"
        },
        "driver_version": {
          "title": "Driver Version",
          "type": "string"
        },
        "runtime_version": {
          "title": "Runtime Version",
          "type": "string"
        },
        "memory_gb": {
          "minimum": 0,
          "title": "Memory Gb",
          "type": "integer"
        },
        "power_limit_w": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Power Limit W"
        },
        "clock_state": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Clock State"
        },
        "mig_mode": {
          "default": false,
          "title": "Mig Mode",
          "type": "boolean"
        },
        "mps_mode": {
          "default": false,
          "title": "Mps Mode",
          "type": "boolean"
        },
        "host_kernel": {
          "title": "Host Kernel",
          "type": "string"
        },
        "container_runtime": {
          "title": "Container Runtime",
          "type": "string"
        },
        "tool_versions": {
          "$ref": "#/$defs/ToolVersionSet"
        }
      },
      "required": [
        "vendor",
        "gpu_name",
        "arch",
        "driver_version",
        "runtime_version",
        "memory_gb",
        "host_kernel",
        "container_runtime",
        "tool_versions"
      ],
      "title": "HardwareFingerprint",
      "type": "object"
    },
    "ToolStatus": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "default": "1.0.0",
          "title": "Schema Version",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Path"
        },
        "version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Version"
        },
        "available": {
          "title": "Available",
          "type": "boolean"
        }
      },
      "required": [
        "name",
        "available"
      ],
      "title": "ToolStatus",
      "type": "object"
    },
    "ToolVersionSet": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "default": "1.0.0",
          "title": "Schema Version",
          "type": "string"
        },
        "versions": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Versions",
          "type": "object"
        }
      },
      "title": "ToolVersionSet",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "host_platform": {
      "title": "Host Platform",
      "type": "string"
    },
    "host_kernel": {
      "title": "Host Kernel",
      "type": "string"
    },
    "python_executable": {
      "title": "Python Executable",
      "type": "string"
    },
    "python_version": {
      "title": "Python Version",
      "type": "string"
    },
    "container_runtime": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Container Runtime"
    },
    "available_tools": {
      "items": {
        "$ref": "#/$defs/ToolStatus"
      },
      "title": "Available Tools",
      "type": "array"
    },
    "hardware_fingerprints": {
      "items": {
        "$ref": "#/$defs/HardwareFingerprint"
      },
      "title": "Hardware Fingerprints",
      "type": "array"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "host_platform",
    "host_kernel",
    "python_executable",
    "python_version"
  ],
  "title": "DoctorReport",
  "type": "object"
}
